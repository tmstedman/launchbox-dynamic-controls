<Controllers>
    <Controller name="Pad" default="true" analogToDigital="left">
        <Mapping name="B" input="ButtonA" />
        <Mapping name="A" input="ButtonB" />
        <Mapping name="L" input="ButtonLeftShoulder" />
        <Mapping name="R" input="ButtonRightShoulder" />
        <Mapping name="Z" input="AxisTriggerRight" />
        <Mapping name="Start" input="ButtonStart" />
        <Mapping name="Stick-Any" input="AxisLeftStick" />
        <Mapping name="Stick-Up" input="AxisLeftStickUp" />
        <Mapping name="Stick-Down" input="AxisLeftStickDown" />
        <Mapping name="Stick-Left" input="AxisLeftStickLeft" />
        <Mapping name="Stick-Right" input="AxisLeftStickRight" />
        <Mapping name="Dpad-Any" input="ButtonDpad" />
        <Mapping name="Dpad-Up" input="ButtonDpadUp" />
        <Mapping name="Dpad-Down" input="ButtonDpadDown" />
        <Mapping name="Dpad-Left" input="ButtonDpadLeft" />
        <Mapping name="Dpad-Right" input="ButtonDpadRight" />
        <Mapping name="C-Any" input="AxisRightStick" />
        <Mapping name="C-Up" input="AxisRightStickUp" />
        <Mapping name="C-Down" input="AxisRightStickDown" />
        <Mapping name="C-Left" input="AxisRightStickLeft" />
        <Mapping name="C-Right" input="AxisRightStickRight" />
    </Controller>
</Controllers>
