<Controllers>
    <Controller name="Pad" analogToDigital="left" default="true">
        <Mapping name="B" input="ButtonA" />
        <Mapping name="A" input="ButtonB" />
        <Mapping name="L" input="ButtonLeftShoulder" />
        <Mapping name="R" input="ButtonRightShoulder" />
        <Mapping name="Start" input="ButtonStart" />
        <Mapping name="Select" input="ButtonBack" />
        <Mapping name="L-Any" input="ButtonDpad" />
        <Mapping name="L-Up" input="ButtonDpadUp" />
        <Mapping name="L-Down" input="ButtonDpadDown" />
        <Mapping name="L-Left" input="ButtonDpadLeft" />
        <Mapping name="L-Right" input="ButtonDpadRight" />
        <Mapping name="R-Any" input="AxisRightStick" />
        <Mapping name="R-Up" input="AxisRightStickUp" />
        <Mapping name="R-Down" input="AxisRightStickDown" />
        <Mapping name="R-Left" input="AxisRightStickLeft" />
        <Mapping name="R-Right" input="AxisRightStickRight" />
    </Controller>
</Controllers>
