<Controllers>
    <Controller name="Pad" default="true" analogToDigital="left">
        <Mapping name="B" input="ButtonA" />
        <Mapping name="A" input="ButtonB" />
        <Mapping name="Start" input="ButtonStart" />
        <Mapping name="X-Any" input="ButtonDpad" />
        <Mapping name="X-Up" input="ButtonDpadUp" />
        <Mapping name="X-Down" input="ButtonDpadDown" />
        <Mapping name="X-Left" input="ButtonDpadLeft" />
        <Mapping name="X-Right" input="ButtonDpadRight" />
        <Mapping name="Y-Up" input="ButtonLeftShoulder" />
        <Mapping name="Y-Down" input="ButtonRightShoulder" />
        <Mapping name="Y-Left" input="AxisTriggerLeft" />
        <Mapping name="Y-Right" input="AxisTriggerRight" />
        <!-- Emulator controls -->
        <Mapping name="RotateScreen" input="ButtonBack" />
    </Controller>
</Controllers>
