<!--
Dynamic Controls
Type: Pause Theme
Adapted from the "PauseShift" pause theme (v1.0) by Faeran, with thanks.
-->

<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dc="clr-namespace:DynamicControls.LaunchBox;assembly=DynamicControls.LaunchBox"
             mc:Ignorable="d"
             d:DesignHeight="562"
             d:DesignWidth="1000"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             FocusVisualStyle="{x:Null}"
             BorderThickness="0"
             Margin="0"
             Padding="0"
             Background="#000">

    <!-- STYLING OF TEXT LIST -->
    <UserControl.Resources>
        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource FindAncestor, AncestorLevel=1, AncestorType={x:Type ItemsControl}}}" />
            <Setter Property="VerticalContentAlignment" Value="{Binding VerticalContentAlignment, RelativeSource={RelativeSource FindAncestor, AncestorLevel=1, AncestorType={x:Type ItemsControl}}}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0"
                        Padding="0,18,0,15" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentStringFormat="{TemplateBinding ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            SnapsToDevicePixels="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#5F3399FF" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5F3399FF" />
                            </MultiTrigger>
                            <MultiTrigger>

                                <!-- WHEN ITEM IS SELECTED -->
                            <MultiTrigger.Conditions>
                                    <Condition Property="Selector.IsSelectionActive" Value="False" />
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Bd" Property="TextElement.Foreground" Value="#A71816"/>
                            </MultiTrigger>

                            <!-- WHEN YOU CLICK ON ONE OF THE ITEMS -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Selector.IsSelectionActive" Value="True" />
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#FF3399FF" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3399FF" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="TextElement.Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXT STYLING -->
        <Style x:Key="ListBoxStyle" TargetType="ListBox">
            <Setter Property="ItemContainerStyle" Value="{DynamicResource ListBoxItemStyle}"></Setter>
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White"></Setter>
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </UserControl.Resources>

    <Canvas Name="Canvas">

        <!-- BACKGROUND IMAGE -->
        <Image Source="{Binding BackgroundImagePath}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
            Height="{Binding ElementName=Canvas, Path=ActualHeight}" Width="{Binding ElementName=Canvas, Path=ActualWidth}">
            <Image.Effect>
                <BlurEffect Radius="60" KernelType="Gaussian"/>
            </Image.Effect>
        </Image>

        <Grid Background="#90000000" Height="{Binding ElementName=Canvas, Path=ActualHeight}" Width="{Binding ElementName=Canvas, Path=ActualWidth}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60*" />
                <ColumnDefinition Width="0.2*" />
                <ColumnDefinition Width="170*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="96*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <!-- CLEAR LOGO + MENU -->
            <Viewbox Grid.Row="1" Grid.Column="0" Stretch="Uniform">
                <Grid Width="400" Height="829">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30*" />
                        <RowDefinition Height="70*" />
                    </Grid.RowDefinitions>

                    <Image Grid.Row="0" Source="{Binding SelectedGame.ClearLogoImagePath}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           MaxHeight="125" Stretch="Uniform" Margin="30,0,30,0"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Effect>
                            <DropShadowEffect BlurRadius="10" Direction="-90" RenderingBias="Quality" ShadowDepth="1" />
                        </Image.Effect>
                    </Image>

                    <ListBox Grid.Row="1" VerticalAlignment="Top" Name="Items" Style="{StaticResource ListBoxStyle}" Opacity="0.8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=Text}" FontSize="30" TextAlignment="Right" Padding="0,0,50,0" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Viewbox>

            <!-- THIS GRABS THE SELECT ITEM TEXT AND PUTS IT INTO A BINDINGS AND POINTS IT TO THE PAUSESHIFT/IMAGE FOLDER -->
            <TextBlock x:Name="SelectedItem"  Visibility="Collapsed">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}pack://siteoforigin:,,,/PauseThemes/Dynamic Controls/Image/{0}.png">
                        <Binding ElementName="Items" Path="SelectedItem.Text" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>

            <!-- THE MIDDLE WHITE RECTANGLE -->
            <Rectangle Grid.Column="1" Grid.Row="1" Fill="White" Margin="-1,0,0,0" Opacity="0.8" />

            <!-- CONTROLLER IMAGE AND PLATFORM LOGO -->
            <Grid Grid.Row="1" Grid.Column="2">

                <!-- CONTROLLER IMAGE WITH DYNAMIC BUTTON LABELS (overlay mode) -->
                <Viewbox Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Canvas Width="{Binding CanvasWidth, Source={x:Static dc:DynamicControlsViewModel.Instance}}"
                            Height="{Binding CanvasHeight, Source={x:Static dc:DynamicControlsViewModel.Instance}}">
                    <ItemsControl ItemsSource="{Binding InputLabels, Source={x:Static dc:DynamicControlsViewModel.Instance}}"
                                  Width="{Binding CanvasWidth, Source={x:Static dc:DynamicControlsViewModel.Instance}}"
                                  Height="{Binding CanvasHeight, Source={x:Static dc:DynamicControlsViewModel.Instance}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" Foreground="White" FontFamily="Segoe UI" FontSize="{Binding FontSize}" FontWeight="SemiBold"
                                           Width="300" TextAlignment="{Binding Alignment}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.Background>
                            <ImageBrush ImageSource="{Binding ControlsImagePath, Source={x:Static dc:DynamicControlsViewModel.Instance}}" Stretch="Uniform"
                                        RenderOptions.BitmapScalingMode="HighQuality" />
                        </ItemsControl.Background>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding RenderedImages, Source={x:Static dc:DynamicControlsViewModel.Instance}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Source}" Width="{Binding Width}" Height="{Binding Height}" Opacity="{Binding Opacity}"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Effect>
                                        <BlurEffect Radius="{Binding BlurRadius}" />
                                    </Image.Effect>
                                </Image>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
                </Viewbox>

                <!-- PLATFORM LOGO OVERLAY: bottom-right corner -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75*" />
                        <ColumnDefinition Width="20*" />
                        <ColumnDefinition Width="5*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="75*" />
                        <RowDefinition Height="25*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Column="1" Grid.Row="1"
                            HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <Image Source="{Binding SelectedGame.PlatformClearLogoImagePath}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <DropShadowEffect BlurRadius="10" Direction="-90" RenderingBias="Quality" ShadowDepth="1" />
                            </Image.Effect>
                        </Image>
                    </Border>
                </Grid>

            </Grid>

        </Grid>
    </Canvas>
</UserControl>
