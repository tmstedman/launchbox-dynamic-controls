<UserControl x:Class="DynamicControls.LaunchBox.ControllerOverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dc="clr-namespace:DynamicControls.LaunchBox;assembly=DynamicControls.LaunchBox">
    <Viewbox Stretch="Uniform">
        <Canvas Width="{Binding CanvasWidth, Source={x:Static dc:DynamicControlsViewModel.Instance}}"
                Height="{Binding CanvasHeight, Source={x:Static dc:DynamicControlsViewModel.Instance}}">
            <ItemsControl ItemsSource="{Binding InputLabels, Source={x:Static dc:DynamicControlsViewModel.Instance}}"
                          Width="{Binding CanvasWidth, Source={x:Static dc:DynamicControlsViewModel.Instance}}"
                          Height="{Binding CanvasHeight, Source={x:Static dc:DynamicControlsViewModel.Instance}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" Foreground="White" FontFamily="Segoe UI" FontSize="{Binding FontSize}" FontWeight="SemiBold"
                                   Width="300" TextAlignment="{Binding Alignment}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.Background>
                    <ImageBrush ImageSource="{Binding ControlsImagePath, Source={x:Static dc:DynamicControlsViewModel.Instance}}" Stretch="Uniform"
                                RenderOptions.BitmapScalingMode="HighQuality" />
                </ItemsControl.Background>
            </ItemsControl>
            <ItemsControl ItemsSource="{Binding RenderedImages, Source={x:Static dc:DynamicControlsViewModel.Instance}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding Source}" Width="{Binding Width}" Height="{Binding Height}" Opacity="{Binding Opacity}"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Effect>
                                <BlurEffect Radius="{Binding BlurRadius}" />
                            </Image.Effect>
                        </Image>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Canvas>
    </Viewbox>
</UserControl>
